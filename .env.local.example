# Supabase project settings (Project Settings → API in the Supabase dashboard)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR-ANON-PUBLIC-KEY

# Only needed locally to run scripts/seed.mjs (create the first admin user).
# NEVER expose this in the browser or commit it — it bypasses Row Level Security.
SUPABASE_SERVICE_ROLE_KEY=YOUR-SERVICE-ROLE-KEY
